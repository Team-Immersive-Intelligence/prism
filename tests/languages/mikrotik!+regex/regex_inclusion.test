	["command", "find"],
	["regex", [
		["parameter", "name"],
		["operator", "~"],
		["punctuation", "\""],
		["anchor", "^"],
		["char-class", [
			["char-class-punctuation", "["],
			["range", [
				"a",
				["range-punctuation", "-"],
				"z"
			]],
			["char-class-punctuation", "]"]
		]],
		["quantifier", "+"],
		["char-set", "\\d"],
		["quantifier", "?"],
		["anchor", "$"],
		["punctuation", "\""]
	]],

	["command", "find"],
	["regex", [
		["parameter", "name"],

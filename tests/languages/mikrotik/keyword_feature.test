:if ($x > 0) do={:put "positive"}
:if ($x > 0) do={:put "yes"} else={:put "no"}
:for i from=1 to=10 step=1 do={:put $i}
:foreach item in=$list do={:put $item}
:while ($x > 0) do={:set x ($x - 1)}
:do {:set x ($x + 1)} while ($x < 10)
/interface monitor-traffic ether1 once
:if ($err != "") do={} on-error={:log error $err}


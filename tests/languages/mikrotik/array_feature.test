:local arr {1;2;3};
:local arr2 {"key1"=val1;"key2"=val2};
:local arr3 {true;false;true};
:local arr4 {192.168.1.1;10.0.0.1};
:local arr5 {"hello";"world"};
:local arr6 {"escaped \n \t";"$myVar"};
:local arr7 {"key1"=val1;"key2"=val2;"key3"=val3};


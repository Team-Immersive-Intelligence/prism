:local x ($a + $b)
:local y ($a - $b)
:local z ($a * $b)
:local w ($a / $b)
:local r ($a % $b)
:if ($a = $b) do={}
:if ($a != $b) do={}
:if ($a < $b) do={}
:if ($a > $b) do={}
:if ($a <= $b) do={}
:if ($a >= $b) do={}
:if (!$flag) do={}
:if ($a && $b) do={}
:if ($a || $b) do={}
:if ($a and $b) do={}
:if ($a or $b) do={}
:if ($x in $list) do={}
:local s ($a . $b)
:local arr ($a , $b)
:local v $arr->0
:local bits ($a & $b)
:local bits2 ($a | $b)
:local bits3 (~$a)
:local bits4 ($a ^ $b)
:local bits5 ($a << 2)
:local bits6 ($a >> 2)


HELLO="Hi, ${NAME}"
FULL="${HELLO}, welcome to ${APP_ENV}"

INTERPOLATED=Multiple $FOO:+false ${BAR-main}\nLines of text
ALSO_INTERPOLATED="Multiple\nLines with a var ${BAZ+42} and an escape sequence \" "
NON_INTERPOLATED='Text without variable (like, $YOLO) interpolation'
MULTILINE_NON_INTERPOLATED=`Long text here (with escape sequences, like \`
or similar),
e.g. a private SSH key (without $VAR interpolation)`

KEY=${FOO:-default}
KEY=${FOO:-false}
KEY=${FOO:-true value}
KEY=$FOO:-false
KEY=$FOO:-false value
KEY=${FOO--42}
KEY=$FOO-42 years
KEY=${FOO:--15}

KEY=${BAR:+alternative}
KEY=${BAR+true}
KEY=${BAR+false value}
KEY=$BAR+true
KEY=$BAR+true value
KEY=${BAR:+42}
KEY=${BAR:+-42}
KEY=${BAR:+42 years}
KEY=$BAR:+42 years
KEY="$FOO:+42"


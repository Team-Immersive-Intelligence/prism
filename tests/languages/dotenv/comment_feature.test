# This is a comment

KEY=VAL # inline comment
KEY="VAL"# and another one
KEY='VAL'# and another one
KEY=`VAL`# and another one

KEY="String with a hash # this is not a comment"
KEY='String with a hash # this is not a comment'
KEY=`String with a hash # this is not a comment`
KEY=VAL# also not a comment
KEY=Escaped \# hash is not a comment as well

----------------------------------------------------


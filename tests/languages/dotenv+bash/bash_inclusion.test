SHORT_HASH=$(git rev-parse --short HEAD)
PWD_MESSAGE="Running from $(pwd)"
DATABASE_URL=postgres://$(whoami)@localhost/my_database

----------------------------------------------------

[
	["assign-left", ["SHORT_HASH"]],
	["operator", ["="]],
	["variable", [
		["variable", "$("],

.foo
#bar
:hover
::before
::selection
> + ~ ||
:nth-child(2n+1)
:nth-child(even)
[type="text" i]
[data-lang|='en']
[data-count=items]
[svg|href$="icon" s]
[attr*=value]
[attr^="start"]
[attr~=token]
[attr|=lang]
[attr=value s]
ul#menu > li.item:not(:first-child) + li[data-role="cta"]::before

